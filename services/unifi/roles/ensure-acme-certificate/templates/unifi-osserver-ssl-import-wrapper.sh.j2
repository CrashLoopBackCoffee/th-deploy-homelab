#!/usr/bin/env bash
# Configured wrapper for unifi-osserver-ssl-import.
# Generated by Ansible — do not edit directly.
set -euo pipefail

tmpscript=$(mktemp)
trap 'rm -f "$tmpscript"' EXIT

# The import script stores its configuration as hardcoded variable assignments at the
# top of the file. Since we vendor it unmodified, we patch those assignments at runtime
# via sed rather than editing the source, so upstream updates can be applied without
# manually reapplying configuration changes.
sed \
  -e 's|^UNIFI_HOSTNAME=.*|UNIFI_HOSTNAME="{{ ensure_acme_certificate_hostname }}"|' \
  -e 's|^CERT_PROVIDER=.*|CERT_PROVIDER="acme"|' \
  -e 's|^DNS_PROVIDER=.*|DNS_PROVIDER="cloudflare"|' \
  /usr/local/sbin/unifi-osserver-ssl-import > "$tmpscript"

exec bash "$tmpscript" "$@"
